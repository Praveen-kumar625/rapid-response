{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist/out-tsc",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@rapid-response/contracts": ["libs/contracts/src"],
      "@rapid-response/db": ["libs/db/src"],
      "@rapid-response/ui": ["libs/ui/src"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
